# ==============================================================================
# AI CV & Recruitment Assistant — Environment Variables
# Copy this file to .env and fill in real values before running the app.
# ==============================================================================

# --- Database ---
# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/recruitment

# --- Redis (used by ARQ task queue) ---
REDIS_URL=redis://localhost:6379/0

# --- LLM Proxy (OpenAI-compatible endpoint) ---
# Set to Azure OpenAI endpoint or any OpenAI-compatible proxy URL
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here

# Optional: Azure-specific settings
# LLM_API_VERSION=2024-02-01
# LLM_DEPLOYMENT_NAME=gpt-4o

# Default models
LLM_CHAT_MODEL=gpt-4o-mini
LLM_EMBED_MODEL=text-embedding-ada-002

# --- Authentication ---
JWT_SECRET=change-this-to-a-long-random-secret-in-production
# JWT algorithm — do not change (HS256 is hardcoded)
# JWT_ALGORITHM=HS256

# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
