# ==============================================================================
# AI CV & Recruitment Assistant — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env with real secrets.
# ==============================================================================

# --- PostgreSQL ---
POSTGRES_DB=recruitment
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/recruitment

# --- Redis ---
REDIS_PASSWORD=changeme
REDIS_URL=redis://localhost:6379/0

# --- LLM Proxy (OpenAI-compatible endpoint) ---
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_CHAT_MODEL=gpt-4o-mini
LLM_EMBED_MODEL=text-embedding-ada-002

# --- Authentication ---
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost/api

# --- Monitoring ---
SENTRY_DSN=
